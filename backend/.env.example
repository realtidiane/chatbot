# ============================================================
# OpenRouter
# ============================================================
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me

# OpenRouter base URL (rarely changes)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App identity (sent to OpenRouter for analytics / leaderboard)
APP_NAME=Chatbot
HTTP_REFERER=http://localhost:5173

# Default model when client does not specify one
DEFAULT_MODEL=openai/gpt-4o-mini

# ============================================================
# Network / CORS
# ============================================================
# Comma-separated list of allowed CORS origins.
# Set to "*" to allow any origin (credentials will be disabled in that mode).
# By default we also allow any LAN address (10.*, 192.168.*, 172.16-31.*) via
# FRONTEND_ORIGIN_REGEX so phones / other devices on the same Wi-Fi work
# out of the box.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# FRONTEND_ORIGIN_REGEX=  # set to override the LAN regex
# Bind options (used only when running `python main.py`):
HOST=0.0.0.0
PORT=8000
RELOAD=1

# ============================================================
# Database (MySQL)
# ============================================================
# Full async SQLAlchemy DSN. Format:
#   mysql+aiomysql://USER:PASSWORD@HOST:PORT/DBNAME
# Example for a local MySQL with root and no password:
#   DATABASE_URL=mysql+aiomysql://root@localhost:3306/chatbot
# With a password (URL-encode special characters):
#   DATABASE_URL=mysql+aiomysql://root:secret@localhost:3306/chatbot
DATABASE_URL=mysql+aiomysql://root@localhost:3306/chatbot

# ============================================================
# Auth (JWT + registration)
# ============================================================
# CHANGE THIS to a long random string before going to production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please-use-a-random-string-of-48-bytes-or-more
JWT_ALGORITHM=HS256
# Token lifetime in minutes. 10080 = 7 days.
JWT_EXPIRE_MINUTES=10080

# Set to "false" to disable public registration (only existing users can log in).
ALLOW_REGISTRATION=true
